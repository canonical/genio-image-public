#cloud-config
ssh_pwauth: True
users:
 - name: ubuntu
   gecos: ubuntu
   uid: 1000
   shell: /bin/bash
   lock_passwd: False
   groups: [ adm, dialout, cdrom, floppy, sudo, audio, dip, video, plugdev, lxd, netdev ]
   plain_text_passwd: 'ubuntu'
chpasswd:
  list: |
    ubuntu:ubuntu
  expire: True
runcmd:
 - |
    sector_size=$(lsblk $(findmnt -n -o SOURCE /) -o PHY-SeC -n | tr -d '[:space:]')
    if [ "$sector_size" -eq 512 ]; then
        echo "$(find /dev/disk/by-path/*boot1) 0x0 0x1000" > /etc/fw_env.config
    else
        # A temporary workaround agreed by Mediatek, we may
        # need a better mechanism to access the correct path
        echo "/dev/sdb 0x0 0x1000" > /etc/fw_env.config
    fi
